# Virtual environment
venv/
.venv/
__pycache__/

# Environment files
.env:
# ============================================================
#  IBM Watsonx.ai — Nutrition Agent Configuration
#  Copy this file to .env and fill in your credentials
# ============================================================

# IBM Cloud API Key (required)
IBM_API_KEY=YOUR_IBM_API_KEY

# IBM Watsonx.ai Project ID (required)
WATSONX_PROJECT_ID=YOUR_PROJECT_ID

# IBM Watsonx.ai URL (default: Dallas region)
WATSONX_URL=IBM_URL

# Flask secret key — change this to a long random string
FLASK_SECRET_KEY=change_me_to_a_secure_random_string_at_least_32_chars

# Flask environment
FLASK_ENV=development
FLASK_DEBUG=True

# Server port
PORT=5000


.env.example:
#.env. example file containt:
.env:
# ============================================================
#  IBM Watsonx.ai — Nutrition Agent Configuration
